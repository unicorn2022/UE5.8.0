RAY_TRACING_ENTRY_CALLABLE(PathTracingHeterogeneousVolumesIntersectCS, FPackedPathTracingPayload, PackedPayload)
{
	ResolvedView = ResolveView();
	FRayDesc Ray = GetHeterogeneousVolumeCallableShaderRay(PackedPayload);

	// Convert ray to local-space
	float3 WorldOrigin = GetHeterogeneousVolumeCallableShaderWorldPos(Ray.Origin);
	float3 WorldDirection = Ray.Direction;
	float3 LocalOrigin = mul(float4(WorldOrigin, 1), PreshadingUniformBuffer.WorldToLocal).xyz;
	float3 LocalDirection = mul(float4(WorldDirection, 0), PreshadingUniformBuffer.WorldToLocal).xyz;

	float2 LocalRayHitT = IntersectAABB(
		LocalOrigin,
		LocalDirection,
		Ray.TMin,
		Ray.TMax,
		PreshadingUniformBuffer.LocalBoundsOrigin - PreshadingUniformBuffer.LocalBoundsExtent,
		PreshadingUniformBuffer.LocalBoundsOrigin + PreshadingUniformBuffer.LocalBoundsExtent
	);

#if 0
	// Refine intersection interval to include non-zero majorant voxels
	if (LocalRayHitT.y - LocalRayHitT.x > 0)
	{
		// Convert to Majorant voxel-space units
		float3 LocalSpanT0 = LocalOrigin + LocalDirection * LocalRayHitT.x;
		float3 LocalSpanT1 = LocalOrigin + LocalDirection * LocalRayHitT.y;
		float3 LocalBoundsMin = PreshadingUniformBuffer.LocalBoundsOrigin - PreshadingUniformBuffer.LocalBoundsExtent;
		float3 LocalBoundsDiagonal = 2.0 * PreshadingUniformBuffer.LocalBoundsExtent;
		float3 MajorantVoxelSpanT0 = (LocalSpanT0 - LocalBoundsMin) / LocalBoundsDiagonal * PreshadingUniformBuffer.MajorantResolution;
		float3 MajorantVoxelSpanT1 = (LocalSpanT1 - LocalBoundsMin) / LocalBoundsDiagonal * PreshadingUniformBuffer.MajorantResolution;

		float3 MajorantVoxelOrigin = MajorantVoxelSpanT0;
		float3 MajorantVoxelDirection = MajorantVoxelSpanT1 - MajorantVoxelSpanT0;
		float MajorantVoxelTMin = 0.0;
		float MajorantVoxelTMax = length(MajorantVoxelDirection);
		MajorantVoxelDirection /= MajorantVoxelTMax;
		float3 MajorantVoxelDirectionInv = 1.0 / MajorantVoxelDirection;
		float VoxelToLocalScale = (LocalRayHitT.y - LocalRayHitT.x) / MajorantVoxelTMax;

		float3 MajorantVoxelPos = MajorantVoxelOrigin;
		float3 MajorantVoxelBounds;
		MajorantVoxelBounds.x = sign(MajorantVoxelDirection.x) > 0 ? floor(MajorantVoxelPos.x) + 1 : ceil(MajorantVoxelPos.x) - 1;
		MajorantVoxelBounds.y = sign(MajorantVoxelDirection.y) > 0 ? floor(MajorantVoxelPos.y) + 1 : ceil(MajorantVoxelPos.y) - 1;
		MajorantVoxelBounds.z = sign(MajorantVoxelDirection.z) > 0 ? floor(MajorantVoxelPos.z) + 1 : ceil(MajorantVoxelPos.z) - 1;

		float3 MajorantVoxelBoundsHitT = (MajorantVoxelBounds - MajorantVoxelPos) * MajorantVoxelDirectionInv;
		// Remove floating-point rounding error
		float Epsilon = 1.0e-4;
		if (MajorantVoxelBoundsHitT.x <= Epsilon) MajorantVoxelBoundsHitT.x += abs(MajorantVoxelDirectionInv.x);
		if (MajorantVoxelBoundsHitT.y <= Epsilon) MajorantVoxelBoundsHitT.y += abs(MajorantVoxelDirectionInv.y);
		if (MajorantVoxelBoundsHitT.z <= Epsilon) MajorantVoxelBoundsHitT.z += abs(MajorantVoxelDirectionInv.z);

		// March in voxel space
		float2 MajorantVoxelRayHitT = float2(MajorantVoxelTMax, MajorantVoxelTMin);
		float MajorantVoxelT = 0;
		while (MajorantVoxelT < MajorantVoxelTMax)
		{
			float MajorantVoxelDeltaT = 0.0;
			if (MajorantVoxelBoundsHitT.x < MajorantVoxelBoundsHitT.y)
			{
				if (MajorantVoxelBoundsHitT.x < MajorantVoxelBoundsHitT.z)
				{
					MajorantVoxelDeltaT = MajorantVoxelBoundsHitT.x - MajorantVoxelT;
					MajorantVoxelBoundsHitT.x += abs(MajorantVoxelDirectionInv.x);
				}
				else
				{
					MajorantVoxelDeltaT = MajorantVoxelBoundsHitT.z - MajorantVoxelT;
					MajorantVoxelBoundsHitT.z += abs(MajorantVoxelDirectionInv.z);
				}
			}
			else
			{
				if (MajorantVoxelBoundsHitT.y < MajorantVoxelBoundsHitT.z)
				{
					MajorantVoxelDeltaT = MajorantVoxelBoundsHitT.y - MajorantVoxelT;
					MajorantVoxelBoundsHitT.y += abs(MajorantVoxelDirectionInv.y);
				}
				else
				{
					MajorantVoxelDeltaT = MajorantVoxelBoundsHitT.z - MajorantVoxelT;
					MajorantVoxelBoundsHitT.z += abs(MajorantVoxelDirectionInv.z);
				}
			}

			// Clip voxel delta-t by overall voxel ray-length.
			if (MajorantVoxelT + MajorantVoxelDeltaT > MajorantVoxelTMax)
			{
				MajorantVoxelDeltaT = MajorantVoxelTMax - MajorantVoxelT;
			}

			// Convert midpoint to UVW for sampling
			float3 MajorantVoxelEndPos = MajorantVoxelPos + MajorantVoxelDirection * MajorantVoxelDeltaT;
			float3 MajorantVoxelSamplePos = (MajorantVoxelPos + MajorantVoxelEndPos) * 0.5;
			float3 UVW = MajorantVoxelSamplePos / PreshadingUniformBuffer.MajorantResolution;

			int MipLevel = 0;
			float3 Majorant = Texture3DSampleLevel(
				PreshadingUniformBuffer.MajorantTexture,
				PreshadingUniformBuffer.PointTextureSampler,
				UVW,
				MipLevel
			).rgb;

			// Expand hit interval if non-zero majorant voxel
			if (any(Majorant > 0))
			{
				MajorantVoxelRayHitT.x = min(MajorantVoxelRayHitT.x, MajorantVoxelT);
				MajorantVoxelRayHitT.y = max(MajorantVoxelRayHitT.y, MajorantVoxelT + MajorantVoxelDeltaT);
			}

			MajorantVoxelT += MajorantVoxelDeltaT;
			MajorantVoxelPos = MajorantVoxelEndPos;
		}

		float LocalRayHitT0 = LocalRayHitT.x;
		LocalRayHitT.x = LocalRayHitT0 + MajorantVoxelRayHitT.x * VoxelToLocalScale;
		LocalRayHitT.y = LocalRayHitT0 + MajorantVoxelRayHitT.y * VoxelToLocalScale;
	}
#endif

	SetHeterogeneousVolumeCallableShaderHitT(LocalRayHitT, PackedPayload);
}

