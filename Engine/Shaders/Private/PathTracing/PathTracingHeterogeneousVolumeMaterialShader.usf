// Specialize GetDensity() to locally fetch from the preshaded volume
FVolumeShadedResult HeterogeneousVolumesGetDensity(float3 TranslatedWorldPos, int HeterogeneousVolumesIndex)
{
	float3 SigmaT = 0;
	float3 Albedo = 0;
	float3 Emission = 0;

	SampleVolumeRenderingCoefficients(TranslatedWorldPos, SigmaT, Albedo, Emission);

	// Return struct
	FVolumeShadedResult Result = (FVolumeShadedResult)0;
	Result.SigmaT = SigmaT;
	Result.SigmaSHG = Albedo * SigmaT;
	Result.PhaseG = GetHeterogeneousVolumeCallableShaderPhaseG();
	Result.Emission = Emission;
	return Result;
}

RAY_TRACING_ENTRY_CALLABLE(PathTracingHeterogeneousVolumesGetDensityCS, FPackedPathTracingPayload, PackedPayload)
{
	ResolvedView = ResolveView();

	float3 SigmaT = 0;
	float3 Albedo = 0;
	float3 Emission = 0;

	float3 TranslatedWorldPos = GetHeterogeneousVolumeCallableShaderTranslatedWorldPos(PackedPayload);
	SampleVolumeRenderingCoefficients(TranslatedWorldPos, SigmaT, Albedo, Emission);

	SetHeterogeneousVolumeCallableShaderSigmaT(SigmaT, PackedPayload);
	SetHeterogeneousVolumeCallableShaderAlbedo(Albedo, PackedPayload);
	SetHeterogeneousVolumeCallableShaderEmission(Emission, PackedPayload);
}

RAY_TRACING_ENTRY_CALLABLE(PathTracingHeterogeneousVolumesSampleDistanceCS, FPackedPathTracingPayload, PackedPayload)
{
	ResolvedView = ResolveView();

	FRandomSequence RandSequence = GetHeterogeneousVolumeCallableShaderRandomSequence(PackedPayload);
	FRayDesc Ray = GetHeterogeneousVolumeCallableShaderRay(PackedPayload);
	float3 PathThroughput = GetHeterogeneousVolumeCallableShaderThroughput(PackedPayload);
	float Majorant = GetHeterogeneousVolumeCallableShaderMajorant(PackedPayload);

	// The tracking interval may represent overlapping volumes, so refine it against the active volume bounds
	{
		float3 WorldOrigin = GetHeterogeneousVolumeCallableShaderWorldPos(Ray.Origin);
		float3 WorldDirection = Ray.Direction;
		float3 LocalOrigin = mul(float4(WorldOrigin, 1), PreshadingUniformBuffer.WorldToLocal).xyz;
		float3 LocalDirection = mul(float4(WorldDirection, 0), PreshadingUniformBuffer.WorldToLocal).xyz;

		 float2 LocalRayHitT = IntersectAABB(
			LocalOrigin,
			LocalDirection,
			Ray.TMin,
			Ray.TMax,
			PreshadingUniformBuffer.LocalBoundsOrigin - PreshadingUniformBuffer.LocalBoundsExtent,
			PreshadingUniformBuffer.LocalBoundsOrigin + PreshadingUniformBuffer.LocalBoundsExtent
		);

		 // Invalid intersection
		 if (LocalRayHitT.x >= LocalRayHitT.y)
		 {
			 SetHeterogeneousVolumeCallableShaderThroughput(PathThroughput, PackedPayload);
			 SetHeterogeneousVolumeCallableShaderPdf(1, PackedPayload);
			 SetHeterogeneousVolumeCallableShaderDistance(Ray.TMax, PackedPayload);
			 SetHeterogeneousVolumeCallableShaderMajorant(0, PackedPayload);
			 SetHeterogeneousVolumeCallableShaderIsCollision(false, PackedPayload);
			 return;
		 }
	}

	bool bTransmittanceOnly = false;
	FVolumeTrackingResult Result = HeterogeneousVolumesMajorantBasedTrackingPreshading(
		PathThroughput,
		Ray.Origin,
		Ray.Direction,
		Ray.TMin,
		Ray.TMax,
		bTransmittanceOnly,
		CreateMajorantData(Majorant),
		RandSequence
	);

	SetHeterogeneousVolumeCallableShaderThroughput(Result.Throughput, PackedPayload);
	SetHeterogeneousVolumeCallableShaderPdf(Result.Pdf, PackedPayload);
	SetHeterogeneousVolumeCallableShaderDistance(Result.Distance, PackedPayload);
	SetHeterogeneousVolumeCallableShaderSigmaBar(Result.SigmaBar, PackedPayload);
	SetHeterogeneousVolumeCallableShaderIsCollision(Result.bIsCollision, PackedPayload);

	SetHeterogeneousVolumeCallableShaderRandomSequence(RandSequence, PackedPayload);
}

RAY_TRACING_ENTRY_CALLABLE(PathTracingHeterogeneousVolumesGetTransmittanceCS, FPackedPathTracingPayload, PackedPayload)
{
	ResolvedView = ResolveView();

	FRandomSequence RandSequence = GetHeterogeneousVolumeCallableShaderRandomSequence(PackedPayload);
	FRayDesc Ray = GetHeterogeneousVolumeCallableShaderRay(PackedPayload);
	float3 PathThroughput = GetHeterogeneousVolumeCallableShaderThroughput(PackedPayload);

	bool bTransmittanceOnly = true;
	FMajorantData EmptyOverlappingMajorant = CreateMajorantData(0.0f);
	FVolumeTrackingResult Result = HeterogeneousVolumesMajorantBasedTrackingPreshading(
		PathThroughput,
		Ray.Origin,
		Ray.Direction,
		Ray.TMin,
		Ray.TMax,
		bTransmittanceOnly,
		EmptyOverlappingMajorant,
		RandSequence
	);

	SetHeterogeneousVolumeCallableShaderThroughput(Result.Throughput, PackedPayload);
	SetHeterogeneousVolumeCallableShaderRandomSequence(RandSequence, PackedPayload);
}
