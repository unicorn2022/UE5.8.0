void SetHeterogeneousVolumeCallableShaderIsCollision(
	bool bIsCollision,
	inout FPackedPathTracingPayload Payload
)
{
	Payload.PackedData[5] = bIsCollision ? 1 : 0;
}

bool GetHeterogeneousVolumeCallableShaderIsCollision(
	FPackedPathTracingPayload Payload
)
{
	bool bIsCollision = Payload.PackedData[5] == 1 ? true : false;
	return bIsCollision;
}
