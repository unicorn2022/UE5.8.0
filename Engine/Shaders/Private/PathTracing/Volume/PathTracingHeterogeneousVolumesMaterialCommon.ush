#pragma once

#include "../../Common.ush"

// Transform

float3 GetHeterogeneousVolumeCallableShaderWorldPos(float3 TranslatedWorldPos)
{
	float3 WorldPos = DFFastLocalSubtractDemote(TranslatedWorldPos, PrimaryView.PreViewTranslation);
	return WorldPos;
}

float3 GetHeterogeneousVolumeCallableShaderTranslatedWorldPos(float3 WorldPos)
{
	float3 TranslatedWorldPos = DFFastToTranslatedWorld(WorldPos, PrimaryView.PreViewTranslation);
	return TranslatedWorldPos;
}

// Shading

float GetHeterogeneousVolumeCallableShaderPhaseG()
{
	return 0.0;
}

// Intersection

void SetHeterogeneousVolumeCallableShaderHitT(
	float2 HitT,
	inout FPackedPathTracingPayload Payload
)
{
	Payload.HitT = HitT.x;
	Payload.PackedData[0] = asuint(HitT.y);
}

float2 GetHeterogeneousVolumeCallableShaderHitT(
	FPackedPathTracingPayload Payload
)
{
	float2 HitT;
	HitT.x = Payload.HitT;
	HitT.y = asfloat(Payload.PackedData[0]);
	return HitT;
}

// Delta Tracking

void SetHeterogeneousVolumeCallableShaderRay(
	FRayDesc Ray,
	inout FPackedPathTracingPayload Payload
)
{
	Payload.HitT = Ray.TMin;
	Payload.PackedData[0] = asuint(Ray.TMax);
	
	Payload.PackedData[1] = asuint(Ray.Origin.x);
	Payload.PackedData[2] = asuint(Ray.Origin.y);
	Payload.PackedData[3] = asuint(Ray.Origin.z);

	Payload.PackedData[4] = asuint(Ray.Direction.x);
	Payload.PackedData[5] = asuint(Ray.Direction.y);
	Payload.PackedData[6] = asuint(Ray.Direction.z);
}

FRayDesc GetHeterogeneousVolumeCallableShaderRay(
	FPackedPathTracingPayload Payload
)
{
	FRayDesc Ray;
	Ray.TMin = Payload.HitT;
	Ray.TMax = asfloat(Payload.PackedData[0]);

	Ray.Origin.x = asfloat(Payload.PackedData[1]);
	Ray.Origin.y = asfloat(Payload.PackedData[2]);
	Ray.Origin.z = asfloat(Payload.PackedData[3]);

	Ray.Direction.x = asfloat(Payload.PackedData[4]);
	Ray.Direction.y = asfloat(Payload.PackedData[5]);
	Ray.Direction.z = asfloat(Payload.PackedData[6]);
	return Ray;
}

void SetHeterogeneousVolumeCallableShaderRandomSequence(
	FRandomSequence RandSeq,
	inout FPackedPathTracingPayload Payload
)
{
	Payload.PackedData[7] = RandSeq.SampleIndex;
	Payload.PackedData[8] = RandSeq.SampleSeed;
}

FRandomSequence GetHeterogeneousVolumeCallableShaderRandomSequence(
	FPackedPathTracingPayload Payload
)
{
	FRandomSequence RandSeq;
	RandSeq.SampleIndex = Payload.PackedData[7];
	RandSeq.SampleSeed = Payload.PackedData[8];
	return RandSeq;
}

void SetHeterogeneousVolumeCallableShaderThroughput(
	float3 Throughput,
	inout FPackedPathTracingPayload Payload
)
{
	Payload.PackedData[9] = asuint(Throughput.x);
	Payload.PackedData[10] = asuint(Throughput.y);
	Payload.PackedData[11] = asuint(Throughput.z);
}

float3 GetHeterogeneousVolumeCallableShaderThroughput(
	FPackedPathTracingPayload Payload
)
{
	float3 Throughput = 0;
	Throughput.x = asfloat(Payload.PackedData[9]);
	Throughput.y = asfloat(Payload.PackedData[10]);
	Throughput.z = asfloat(Payload.PackedData[11]);
	return Throughput;
}

void SetHeterogeneousVolumeCallableShaderMajorant(
	float Majorant,
	FPackedPathTracingPayload Payload
)
{
	Payload.PackedData[12] = asuint(Majorant);
}

float GetHeterogeneousVolumeCallableShaderMajorant(
	FPackedPathTracingPayload Payload
)
{
	float Majorant = asfloat(Payload.PackedData[12]);
	return Majorant;
}

