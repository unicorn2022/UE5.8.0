<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:GRS.Features.Debug.UIX.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="UIX.Views.Display.ImageWatchpointDisplayStatusView"
             x:DataType="viewModels:ImageWatchpointDisplayViewModel">
    <StackPanel 
        Orientation="Horizontal"
        Spacing="5"
        Height="25">
        <TextBlock
            VerticalAlignment="Center"
            Text="{Binding PixelDecoration}"/>
        
        <Border
            Width="15"
            Height="13"
            VerticalAlignment="Center"
            Background="{Binding PixelColor}"/>
    </StackPanel>
</UserControl>
