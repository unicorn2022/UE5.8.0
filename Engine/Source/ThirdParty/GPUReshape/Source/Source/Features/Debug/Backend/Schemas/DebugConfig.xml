<schema>
    <message name="DebugWatchpoint">
        <field name="codeOffset" type="uint32"/>
        <field name="uid" type="uint32"/>
        <field name="flags" type="uint32"/>
        <field name="variableId" type="uint32"/>
        <field name="valueId" type="uint32"/>
        <field name="markerHash32" type="uint32"/>
    </message>
    
    <message name="DebugConfig">
        <field name="watchpoints" type="stream"/>
    </message>

    <message name="DebugWatchpointStreamHandled">
        <field name="request" type="uint32"/>
    </message>

    <message name="RegisterDebugWatchpoint">
        <field name="uid" type="uint32"/>
        <field name="streamSize" type="uint32"/>
        <field name="captureMode" type="uint32"/>
    </message>

    <message name="ReallocateDebugWatchpoint">
        <field name="uid" type="uint32"/>
        <field name="streamSize" type="uint32"/>
    </message>

    <message name="DeregisterDebugWatchpoint">
        <field name="uid" type="uint32"/>
    </message>

    <message name="DebugWatchpointStream">
        <field name="request" type="uint32"/>
        <field name="uid" type="uint32"/>
        <field name="captureMode" type="uint32"/>
        <field name="data" type="array" element="uint8"/>
        <field name="dataFormat" type="uint32"/>
        <field name="dataTypeId" type="uint32"/>
        <field name="dataTinyType" type="array" element="uint8"/>
        <field name="dataCompression" type="uint32"/>
        <field name="dataDWordStride" type="uint32"/>
        <field name="dataOrder" type="uint32"/>
        <field name="dataStaticWidth" type="uint32"/>
        <field name="dataStaticHeight" type="uint32"/>
        <field name="dataStaticDepth" type="uint32"/>
        <field name="dataDynamicCounter" type="uint32"/>
        <field name="dataRequestStreamSize" type="uint32"/>
    </message>

    <message name="DebugWatchpointValueMetadata">
        <field name="name" type="string"/>
        <field name="valueId" type="uint32"/>
        <field name="hasReconstruction" type="bool"/>
    </message>

    <message name="DebugWatchpointVariableMetadata">
        <field name="name" type="string"/>
        <field name="variableId" type="uint32"/>
        <field name="dataTinyType" type="array" element="uint8"/>
        <field name="values" type="stream"/>
    </message>
    
    <message name="DebugWatchpointMetadata">
        <field name="uid" type="uint32"/>
        <field name="variables" type="stream"/>
    </message>
</schema>
