<UserControl x:Class="UIX.Views.Tools.WatchpointTreeView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:tools="clr-namespace:GRS.Features.Debug.UIX.ViewModels.Tools"
             xmlns:cvm="clr-namespace:Studio.ViewModels.Controls;assembly=UIX.Studio.Runtime"
             mc:Ignorable="d"
             d:DesignWidth="300" d:DesignHeight="400"
             x:DataType="tools:WatchpointTreeViewModel" x:CompileBindings="True">
    <Grid Focusable="True" RowDefinitions="Auto,*">
        <TreeView 
            Grid.Row="1" 
            x:Name="WatchpointTree" 
            ContextMenu="{StaticResource ReactiveContextMenu}" 
            BorderThickness="0"
            AutoScrollToSelectedItem="False"
            SelectionMode="Multiple"
            Tag="{Binding}"
            ItemsSource="{Binding Root.Items}">
            <TreeView.Styles>
                <Style Selector="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding Path=(cvm:IObservableTreeItem).IsExpanded}"/>
                </Style>
            </TreeView.Styles>
            <TreeView.ItemTemplate>
                <TreeDataTemplate ItemsSource="{Binding (cvm:IObservableTreeItem).Items}">
                    <StackPanel 
                        Orientation="Horizontal"
                        Height="20"
                        Spacing="5"
                        IsHitTestVisible="False">
                        <Border
                            CornerRadius="5"
                            Background="#DB5C5C"
                            Width="10"
                            Height="10"/>
                        
                        <TextBlock 
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Text="{Binding (cvm:IObservableTreeItem).Text}"/>
                    </StackPanel>
                </TreeDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>

        <Grid
            Grid.Row="1"
            IsVisible="{Binding IsHelpVisible}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <PathIcon
                    Data="{StaticResource InfoHollow}"
                    VerticalAlignment="Center"
                    Margin="0 0 0 0"
                    Width="10" />
                <TextBlock
                    Margin="5 0 0 0"
                    Foreground="{StaticResource InfoMediumForeground}"
                    VerticalAlignment="Center"
                    Text=" No watchpoints" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>