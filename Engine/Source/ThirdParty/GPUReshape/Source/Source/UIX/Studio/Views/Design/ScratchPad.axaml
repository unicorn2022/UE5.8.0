<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:Studio.Views.Controls;assembly=UIX.Studio.Runtime"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Studio.Views.Design.ScratchPad">
    <!--
        Purely a design-time assistant, unfortunately plugins do not support design previews, 
        which is detrimental to development time. So, have this little scratch pad for testing.
    -->
</UserControl>
