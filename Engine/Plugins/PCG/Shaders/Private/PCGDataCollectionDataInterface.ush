float3 GetFirstAttributeAsRotator_{NameSuffix}_{DataInterfaceName}()
{
	return GetFirstAttributeAsFloat3_{NameSuffix}_{DataInterfaceName}();
}

float4 GetFirstAttributeAsQuat_{NameSuffix}_{DataInterfaceName}()
{
	return GetFirstAttributeAsFloat4_{NameSuffix}_{DataInterfaceName}();
}

float4x4 GetFirstAttributeAsTransform_{NameSuffix}_{DataInterfaceName}()
{
	const uint AttributeAddress = GetFirstValidAttributeElementInternal_{NameSuffix}_{DataInterfaceName}();
	if (AttributeAddress == 0)
	{
		return (float4x4)0;
	}

	return float4x4(
		asfloat({DataInterfaceName}_DataCollectionBuffer{BufferSuffix}.Load4(AttributeAddress)),
		asfloat({DataInterfaceName}_DataCollectionBuffer{BufferSuffix}.Load4(AttributeAddress + 4 * 4)),
		asfloat({DataInterfaceName}_DataCollectionBuffer{BufferSuffix}.Load4(AttributeAddress + 8 * 4)),
		asfloat({DataInterfaceName}_DataCollectionBuffer{BufferSuffix}.Load4(AttributeAddress + 12 * 4))
	);
}

int GetFirstAttributeAsStringKey_{NameSuffix}_{DataInterfaceName}()
{
	// String keys are represented as ints.
	return GetFirstAttributeAsInt_{NameSuffix}_{DataInterfaceName}();
}

int GetFirstAttributeAsName_{NameSuffix}_{DataInterfaceName}()
{
	// Names are represented as ints.
	return GetFirstAttributeAsInt_{NameSuffix}_{DataInterfaceName}();
}
