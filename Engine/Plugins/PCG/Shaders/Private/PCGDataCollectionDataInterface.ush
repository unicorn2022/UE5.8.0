// Copyright Epic Games, Inc. All Rights Reserved.

// Buffer format:
//
// -- START HEADER --
// NumData (4B)
// For each data (1036B when MAX_NUM_ATTR=128):
//   TypeId (4B)
//   Attribute Count (4B)
//   Element Count (4B)
//   For attribute ID in [0, MAX_NUM_ATTR-1]:
//     PackedAttributeInfo (4B)
//         Stride (8b)
//         Id (23b)
//         Allocated (1b - MSB)
//     AttributeElementStartAddress (4B)
// -- END HEADER --
// For each data:
//   For each present attribute:
//     <Packed element data> (element count * stride bytes) - Note: element count may be 1 if the attribute is not 'Allocated' (that is, uses a single value for the entire range).

ByteAddressBuffer {DataInterfaceName}_DataCollectionBufferSRV;
RWByteAddressBuffer {DataInterfaceName}_DataCollectionBufferUAV;

// Multiplier that can be configured on output pins.
uint {DataInterfaceName}_ElementCountMultiplier;

// Union of EPCGPointNativeProperties bits across ALL output data items. Non-zero bit = that property is N-slot (fully allocated)
// in at least one data item. Set from C++ at dispatch time; cheaper to read than querying the buffer header per-thread.
// Consequence for multi-data: if a property is N-slot in any data item, the preamble does per-element copies for ALL data
// items, including those where the property is CVR - those writes are redundant but harmless (all hit slot 0 via bAllocated clamping).
// todo_pcg: could be moved into the per-data GPU buffer header, making it truly per-data and eliminating redundant preamble copies.
uint {DataInterfaceName}_AllocatedNativePropertiesMask;

StructuredBuffer<int> {DataInterfaceName}_GraphToBufferAttributeId;

int {DataInterfaceName}_FirstRemappedAttributeId;

StructuredBuffer<int> {DataInterfaceName}_BufferToGraphStringKey;

int {DataInterfaceName}_NumRemappedStringKeys;

struct FPCGAttributeHeader_{DataInterfaceName}
{
	/** Absolute address of this attribute's first data element in the buffer. */
	uint FirstElementAddress;

	/** Stride (in bytes) of this attribute. */
	uint Stride;

	/** Whether or not this attribute is full-width allocated. */
	bool bAllocated;
};

// #################### SHADER PARAM GETTERS ##########################

// @todo_pcg: This parameter is broader than this data interface. Needs to be shared in some way (e.g. with TextureDataInterface).
uint GetElementCountMultiplier_{DataInterfaceName}()
{
	return {DataInterfaceName}_ElementCountMultiplier;
}

// Returns the union of EPCGPointNativeProperties bits across all output data items. Non-zero bit = that property is N-slot
// (fully allocated) in at least one data item. Used in the processor preamble to branch between CVR (write at element 0)
// and N-slot (write per-element) copies. See comment on the uniform above for multi-data implications.
uint GetAllocatedNativePropertiesMask_{DataInterfaceName}()
{
	return {DataInterfaceName}_AllocatedNativePropertiesMask;
}

// #################### HEADER READERS ##########################

// Begin section which will have {NameSuffix} and {BufferSuffix} injected for both SRV and UAV use.
{{BeginDuplicateForSRVUAV}}

uint GetNumData_{NameSuffix}_{DataInterfaceName}()
{
	return {DataInterfaceName}_DataCollectionBuffer{BufferSuffix}.Load(0);
}

uint GetNumElements_{NameSuffix}_{DataInterfaceName}(uint InDataIndex)
{
	const uint ReadAddress =
		PCG_DATA_COLLECTION_HEADER_SIZE_BYTES +
		InDataIndex * PCG_DATA_HEADER_SIZE_BYTES +
		/*TypeId*/4 + /*Attribute Count*/4;

	return {DataInterfaceName}_DataCollectionBuffer{BufferSuffix}.Load(ReadAddress);
}

bool GetThreadData_{NameSuffix}_{DataInterfaceName}(uint InThreadIndex, out uint OutDataIndex, out uint OutElementIndex)
{
	int ElementIndex = (int)InThreadIndex;

	const uint NumData = GetNumData_{NameSuffix}_{DataInterfaceName}();
	for (uint DataIndex = 0; DataIndex < NumData; ++DataIndex)
	{
		const int ElemCount = (int)GetNumElements_{NameSuffix}_{DataInterfaceName}(DataIndex);

		if (ElementIndex < ElemCount)
		{
			OutDataIndex = DataIndex;
			OutElementIndex = (uint)ElementIndex;
			return true;
		}

		ElementIndex -= ElemCount;
	}

	OutDataIndex = (uint)-1;
	OutElementIndex = (uint)-1;
	return false;
}

uint GetNumElements_{NameSuffix}_{DataInterfaceName}()
{
	uint NumElements = 0;

	const uint NumData = GetNumData_{NameSuffix}_{DataInterfaceName}();
	for (uint DataIndex = 0; DataIndex < NumData; ++DataIndex)
	{
		NumElements += GetNumElements_{NameSuffix}_{DataInterfaceName}(DataIndex);
	}

	return NumElements;
}

{{EndDuplicateForSRVUAV}}

// #################### INTERNAL HELPERS ##########################

// Begin section which will have {NameSuffix} and {BufferSuffix} injected for both SRV and UAV use.
{{BeginDuplicateForSRVUAV}}

uint LoadBufferInternal_{NameSuffix}_{DataInterfaceName}(uint InAddress)
{
	return {DataInterfaceName}_DataCollectionBuffer{BufferSuffix}.Load(InAddress);
}

{{EndDuplicateForSRVUAV}}

// Begin section which will have {NameSuffix} and {BufferSuffix} injected for UAV use.
{{BeginUAVOnly}}

void StoreBufferInternal_{NameSuffix}_{DataInterfaceName}(uint InAddress, uint InValue)
{
	{DataInterfaceName}_DataCollectionBuffer{BufferSuffix}.Store(InAddress, InValue);
}

{{EndUAVOnly}}

int GetRemappedAttributeIdInternal_{DataInterfaceName}(int InGraphAttributeId)
{
	if (InGraphAttributeId >= {DataInterfaceName}_FirstRemappedAttributeId)
	{
		// Convert from current compute graph attribute ID present in buffer (required if buffer came from a different upstream compute graph).
		// Note: InGraphAttributeId should always be >= PCG_NUM_RESERVED_ATTRS, but max() added to appease compilers.
		return PCG_NUM_RESERVED_ATTRS + {DataInterfaceName}_GraphToBufferAttributeId[max(0, InGraphAttributeId - PCG_NUM_RESERVED_ATTRS)];
	}
	else
	{
		return InGraphAttributeId;
	}
}

// Begin section which will have {NameSuffix} and {BufferSuffix} injected for both SRV and UAV use.
{{BeginDuplicateForSRVUAV}}
FPCGAttributeHeader_{DataInterfaceName} GetAttributeHeaderInternal_{NameSuffix}_{DataInterfaceName}(uint InDataIndex, int InAttributeId)
{
	const int AttributeId = GetRemappedAttributeIdInternal_{DataInterfaceName}(InAttributeId);

	const uint ReadAddress =
		PCG_DATA_COLLECTION_HEADER_SIZE_BYTES +
		InDataIndex * PCG_DATA_HEADER_SIZE_BYTES +
		/*TypeId*/4 + /*Attribute Count*/4 + /*Element Count*/4 +
		AttributeId * PCG_ATTRIBUTE_HEADER_SIZE_BYTES;

	const uint2 PackedAttributeHeader = {DataInterfaceName}_DataCollectionBuffer{BufferSuffix}.Load2(ReadAddress);

	FPCGAttributeHeader_{DataInterfaceName} AttributeHeader;
	AttributeHeader.FirstElementAddress = PackedAttributeHeader.y;
	AttributeHeader.Stride = PackedAttributeHeader.x & PCG_ATTRIBUTE_STRIDE_MASK;
	AttributeHeader.bAllocated = (PackedAttributeHeader.x & PCG_ATTRIBUTE_ALLOCATED_MASK) != 0;

	return AttributeHeader;
}

uint2 GetElementAddressAndStrideInternal_{NameSuffix}_{DataInterfaceName}(uint InDataIndex, uint InElementIndex, int InAttributeId)
{
	const FPCGAttributeHeader_{DataInterfaceName} AttributeHeader = GetAttributeHeaderInternal_{NameSuffix}_{DataInterfaceName}(InDataIndex, InAttributeId);
	const uint ElementIndex = AttributeHeader.bAllocated ? InElementIndex : 0u;

	return uint2(ElementIndex * AttributeHeader.Stride + AttributeHeader.FirstElementAddress, AttributeHeader.Stride);
}

uint GetElementAddressInternal_{NameSuffix}_{DataInterfaceName}(uint InDataIndex, uint InElementIndex, int InAttributeId)
{
	return GetElementAddressAndStrideInternal_{NameSuffix}_{DataInterfaceName}(InDataIndex, InElementIndex, InAttributeId).x;
}

uint GetFirstValidAttributeElementInternal_{NameSuffix}_{DataInterfaceName}()
{
	for (int AttributeId = 0; AttributeId < PCG_MAX_NUM_ATTRS; ++AttributeId)
	{
		const uint ElementAddress = GetElementAddressInternal_{NameSuffix}_{DataInterfaceName}(/*DataIndex=*/0, /*ElementIndex=*/0, AttributeId);

		if (ElementAddress > 0)
		{
			return ElementAddress;
		}
	}

	return 0;
}

uint GetDataNumAttributesInternal_{NameSuffix}_{DataInterfaceName}(uint InDataIndex)
{
	const uint ReadAddress =
		PCG_DATA_COLLECTION_HEADER_SIZE_BYTES +
		InDataIndex * PCG_DATA_HEADER_SIZE_BYTES +
		/*TypeId*/4;

	return {DataInterfaceName}_DataCollectionBuffer{BufferSuffix}.Load(ReadAddress);
}
{{EndDuplicateForSRVUAV}}

