{{BeginDuplicateForSRVUAV}}

uint GetUint_{NameSuffix}_{DataInterfaceName}(uint InDataIndex, uint InElementIndex, int InAttributeId)
{
	const uint ElementAddress = GetElementAddressInternal_{NameSuffix}_{DataInterfaceName}(InDataIndex, InElementIndex, InAttributeId);

	if (ElementAddress > 0)
	{
		return {DataInterfaceName}_DataCollectionBuffer{BufferSuffix}.Load(ElementAddress);
	}
	else
	{
		return 0u;
	}
}

bool GetBool_{NameSuffix}_{DataInterfaceName}(uint InDataIndex, uint InElementIndex, int InAttributeId)
{
	return GetUint_{NameSuffix}_{DataInterfaceName}(InDataIndex, InElementIndex, InAttributeId) != 0;
}

int GetInt_{NameSuffix}_{DataInterfaceName}(uint InDataIndex, uint InElementIndex, int InAttributeId)
{
	return asint(GetUint_{NameSuffix}_{DataInterfaceName}(InDataIndex, InElementIndex, InAttributeId));
}

float GetFloat_{NameSuffix}_{DataInterfaceName}(uint InDataIndex, uint InElementIndex, int InAttributeId)
{
	return asfloat(GetUint_{NameSuffix}_{DataInterfaceName}(InDataIndex, InElementIndex, InAttributeId));
}

float2 GetFloat2_{NameSuffix}_{DataInterfaceName}(uint InDataIndex, uint InElementIndex, int InAttributeId)
{
	const uint ElementAddress = GetElementAddressInternal_{NameSuffix}_{DataInterfaceName}(InDataIndex, InElementIndex, InAttributeId);

	if (ElementAddress > 0)
	{
		return asfloat({DataInterfaceName}_DataCollectionBuffer{BufferSuffix}.Load2(ElementAddress));
	}
	else
	{
		return (float2)0;
	}
}

float3 GetFloat3_{NameSuffix}_{DataInterfaceName}(uint InDataIndex, uint InElementIndex, int InAttributeId)
{
	const uint ElementAddress = GetElementAddressInternal_{NameSuffix}_{DataInterfaceName}(InDataIndex, InElementIndex, InAttributeId);

	if (ElementAddress > 0)
	{
		return asfloat({DataInterfaceName}_DataCollectionBuffer{BufferSuffix}.Load3(ElementAddress));
	}
	else
	{
		return (float3)0;
	}
}

float4 GetFloat4_{NameSuffix}_{DataInterfaceName}(uint InDataIndex, uint InElementIndex, int InAttributeId)
{
	const uint ElementAddress = GetElementAddressInternal_{NameSuffix}_{DataInterfaceName}(InDataIndex, InElementIndex, InAttributeId);

	if (ElementAddress > 0)
	{
		return asfloat({DataInterfaceName}_DataCollectionBuffer{BufferSuffix}.Load4(ElementAddress));
	}
	else
	{
		return (float4)0;
	}
}

float3 GetRotator_{NameSuffix}_{DataInterfaceName}(uint InDataIndex, uint InElementIndex, int InAttributeId)
{
	return GetFloat3_{NameSuffix}_{DataInterfaceName}(InDataIndex, InElementIndex, InAttributeId);
}

float4 GetQuat_{NameSuffix}_{DataInterfaceName}(uint InDataIndex, uint InElementIndex, int InAttributeId)
{
	return GetFloat4_{NameSuffix}_{DataInterfaceName}(InDataIndex, InElementIndex, InAttributeId);
}

float4x4 GetTransform_{NameSuffix}_{DataInterfaceName}(uint InDataIndex, uint InElementIndex, int InAttributeId)
{
	const uint ElementAddress = GetElementAddressInternal_{NameSuffix}_{DataInterfaceName}(InDataIndex, InElementIndex, InAttributeId);

	if (ElementAddress > 0)
	{
		return float4x4(
			asfloat({DataInterfaceName}_DataCollectionBuffer{BufferSuffix}.Load4(ElementAddress)),
			asfloat({DataInterfaceName}_DataCollectionBuffer{BufferSuffix}.Load4(ElementAddress + 4 * 4)),
			asfloat({DataInterfaceName}_DataCollectionBuffer{BufferSuffix}.Load4(ElementAddress + 8 * 4)),
			asfloat({DataInterfaceName}_DataCollectionBuffer{BufferSuffix}.Load4(ElementAddress + 12 * 4)));
	}
	else
	{
		return (float4x4)0;
	}
}

int GetStringKey_{NameSuffix}_{DataInterfaceName}(uint InDataIndex, uint InElementIndex, int InAttributeId)
{
	// String keys are represented as ints.
	const int StringKey = GetInt_{NameSuffix}_{DataInterfaceName}(InDataIndex, InElementIndex, InAttributeId);
	if (StringKey < {DataInterfaceName}_NumRemappedStringKeys)
	{
		return {DataInterfaceName}_BufferToGraphStringKey[StringKey];
	}
	else
	{
		return StringKey;
	}
}

int GetName_{NameSuffix}_{DataInterfaceName}(uint InDataIndex, uint InElementIndex, int InAttributeId)
{
	// Names are currently put in the string table.
	return GetStringKey_{NameSuffix}_{DataInterfaceName}(InDataIndex, InElementIndex, InAttributeId);
}

