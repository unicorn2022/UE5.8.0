void SetTransform_{NameSuffix}_{DataInterfaceName}(uint InDataIndex, uint InElementIndex, int InAttributeId, float4x4 InValue)
{
	const uint ElementAddress = GetElementAddressInternal_{NameSuffix}_{DataInterfaceName}(InDataIndex, InElementIndex, InAttributeId);

	if (ElementAddress > 0)
	{
		{DataInterfaceName}_DataCollectionBuffer{BufferSuffix}.Store4(ElementAddress, asuint(InValue[0]));
