}

float4x4 GetPointTransform_{NameSuffix}_{DataInterfaceName}(uint InDataIndex, uint InElementIndex)
{
	const FQuat Rotation = GetRotation_{NameSuffix}_{DataInterfaceName}(InDataIndex, InElementIndex);
	const half3x3 RotationMatrix = QuatToMatrix(Rotation);
	const float3 Position = GetPosition_{NameSuffix}_{DataInterfaceName}(InDataIndex, InElementIndex);
	const float3 Scale = GetScale_{NameSuffix}_{DataInterfaceName}(InDataIndex, InElementIndex);

	const float3 Axis0 = Scale.x * RotationMatrix[0];
	const float3 Axis1 = Scale.y * RotationMatrix[1];
	const float3 Axis2 = Scale.z * RotationMatrix[2];

	return float4x4(
		Axis0.x, Axis1.x, Axis2.x, Position.x,
		Axis0.y, Axis1.y, Axis2.y, Position.y,
		Axis0.z, Axis1.z, Axis2.z, Position.z,
		(float3)0.0, 1.0);
}

bool IsPointRemoved_{NameSuffix}_{DataInterfaceName}(uint InDataIndex, uint InElementIndex)
{
	return GetDensity_{NameSuffix}_{DataInterfaceName}(InDataIndex, InElementIndex) == PCG_INVALID_DENSITY;
}
{{EndDuplicateForSRVUAV}}

