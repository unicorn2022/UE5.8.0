	}
}

float3 GetFirstAttributeAsFloat3_{NameSuffix}_{DataInterfaceName}()
{
	const uint AttributeAddress = GetFirstValidAttributeElementInternal_{NameSuffix}_{DataInterfaceName}();

	if (AttributeAddress > 0)
	{
		return asfloat({DataInterfaceName}_DataCollectionBuffer{BufferSuffix}.Load3(AttributeAddress));
	}
	else
	{
		return (float3)0;
	}
}

float4 GetFirstAttributeAsFloat4_{NameSuffix}_{DataInterfaceName}()
{
	const uint AttributeAddress = GetFirstValidAttributeElementInternal_{NameSuffix}_{DataInterfaceName}();

	if (AttributeAddress > 0)
	{
		return asfloat({DataInterfaceName}_DataCollectionBuffer{BufferSuffix}.Load4(AttributeAddress));
